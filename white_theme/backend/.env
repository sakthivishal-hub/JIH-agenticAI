# =====================================================
# APPLICATION
# =====================================================
APP_NAME=Opportunity OS
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# =====================================================
# DATABASE  (Postgres must be running locally — see setup notes)
# =====================================================
DATABASE_URL=postgresql://jihai_user:jihai123@localhost:5432/jihai

# =====================================================
# SECURITY
# =====================================================
SECRET_KEY=AbFtqI-ApQ1oSX7Cl7_mg_9pL6povUoGnZddcVZc6gtA6vuaNFQe3LZmLXPwIoyT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =====================================================
# SEARCH ENGINE (Tavily — already configured, working key)
# =====================================================
TAVILY_API_KEY=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

# =====================================================
# LIVE JOB SEARCH
# Get a free key: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# (RapidAPI -> subscribe to JSearch on the free "Basic" plan -> copy your key)
# =====================================================
JSEARCH_API_KEY=

# Optional extra job source: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# =====================================================
# AI
# Get a free key: https://aistudio.google.com/apikey
# =====================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback if Gemini is down/rate-limited: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# =====================================================
# EMAIL (optional - leave blank to disable email notifications)
# =====================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# =====================================================
# REDIS (optional - leave default if you don't run Redis)
# =====================================================
REDIS_URL=redis://localhost:6379/0

# =====================================================
# FILE UPLOADS
# =====================================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# =====================================================
# CORS - must include every origin your frontend runs on
# =====================================================
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=INFO

# =====================================================
# SCHEDULER
# =====================================================
HACKATHON_REFRESH_HOURS=6
JOB_REFRESH_HOURS=6

# =====================================================
# OPPORTUNITY SETTINGS
# =====================================================
DEFAULT_COUNTRY=India
DEFAULT_LANGUAGE=en
MAX_RESULTS_PER_SOURCE=20

# =====================================================
# AI RECOMMENDATION SETTINGS
# =====================================================
MATCH_THRESHOLD=0.65
TOP_RECOMMENDATIONS=10

# =====================================================
# WHATSAPP (Twilio) - optional
# =====================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=